{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Full Pipeline",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run_analysis.py",
      "args": ["--days", "30", "--posts", "50"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Run Pipeline (skip fetch)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run_analysis.py",
      "args": ["--skip-fetch"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Generate Notebook",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/generate_notebook.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Run Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/", "-v"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ]
}
