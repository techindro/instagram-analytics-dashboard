# ── Tests: process_posts ──────────────────────────────────────────────────────

class TestProcessPosts:
    def test_returns_dataframe(self, sample_posts):
        df = DataProcessor.process_posts(sample_posts)
        assert isinstance(df, pd.DataFrame)

    def test_row_count(self, sample_posts):
        df = DataProcessor.process_posts(sample_posts)
        assert len(df) == len(sample_posts)

    def test_engagement_rate_computed(self, sample_posts):
        df = DataProcessor.process_posts(sample_posts)
        assert "engagement_rate" in df.columns
        assert (df["engagement_rate"] >= 0).all()

    def test_engagement_rate_formula(self, sample_posts):
        df = DataProcessor.process_posts(sample_posts)
        row = df[df["id"] == "1"].iloc[0]
        expected_eng = row["like_count"] + row["comments_count"] + row["saved"] + row["shares"]
        expected_er  = round(expected_eng / row["reach"] * 100, 2)
        assert abs(row["engagement_rate"] - expected_er) < 0.01

    def test_datetime_columns(self, sample_posts):
        df = DataProcessor.process_posts(sample_posts)
        assert "hour" in df.columns
        assert "weekday" in df.columns
        assert df["hour"].between(0, 23).all()

    def test_empty_input(self):
        df = DataProcessor.process_posts([])
        assert df.empty

    def test_total_engagement(self, sample_posts):
        df = DataProcessor.process_posts(sample_posts)
        assert "total_engagement" in df.columns
        assert (df["total_engagement"] >= 0).all()

# ── Tests: process_follower_growth ───────────────────────────────────────────

class TestFollowerGrowth:
    def test_returns_dataframe(self, sample_follower_growth):
        df = DataProcessor.process_follower_growth(sample_follower_growth)
        assert isinstance(df, pd.DataFrame)

    def test_columns_present(self, sample_follower_growth):
        df = DataProcessor.process_follower_growth(sample_follower_growth)
        for col in ["date", "followers", "daily_gain", "growth_rate", "rolling_7"]:
            assert col in df.columns, f"Missing column: {col}"

    def test_sorted_ascending(self, sample_follower_growth):
        df = DataProcessor.process_follower_growth(sample_follower_growth)
        assert (df["followers"].diff().dropna() >= 0).all()

    def test_empty_input(self):
        df = DataProcessor.process_follower_growth([])
        assert df.empty


# ── Tests: process_audience_demographics ─────────────────────────────────────

class TestAudienceDemographics:
    def test_returns_dict(self, sample_audience):
        result = DataProcessor.process_audience_demographics(sample_audience)
        assert isinstance(result, dict)

    def test_gender_key(self, sample_audience):
        result = DataProcessor.process_audience_demographics(sample_audience)
        assert "gender" in result
        assert set(result["gender"]["gender"]).issubset({"Female", "Male", "Other"})

    def test_age_key(self, sample_audience):
        result = DataProcessor.process_audience_demographics(sample_audience)
        assert "age" in result

    def test_city_key(self, sample_audience):
        result = DataProcessor.process_audience_demographics(sample_audience)
        assert "city" in result
        assert result["city"].iloc[0]["city"] == "Mumbai"

    def test_pct_sums_to_100(self, sample_audience):
        result = DataProcessor.process_audience_demographics(sample_audience)
        for key in ["gender", "city", "country"]:
            if key in result:
                total = result[key]["pct"].sum()
                assert abs(total - 100.0) < 0.1, f"{key} pct sums to {total}"

    def test_empty_input(self):
        result = DataProcessor.process_audience_demographics({})
        assert result == {}

# ── Tests: process_hashtags ───────────────────────────────────────────────────

class TestHashtags:
    def test_returns_dataframe(self):
        raw = [
            {"hashtag": "#photography", "our_post_count": 10, "avg_engagement": 500, "ig_media_count": 1_000_000, "total_likes": 4000, "total_comments": 500},
            {"hashtag": "#travel",       "our_post_count": 5,  "avg_engagement": 800, "ig_media_count": 5_000_000, "total_likes": 3500, "total_comments": 500},
        ]
        df = DataProcessor.process_hashtags(raw)
        assert isinstance(df, pd.DataFrame)
        assert len(df) == 2

    def test_sorted_by_engagement(self):
        raw = [
            {"hashtag": "#a", "our_post_count": 1, "avg_engagement": 100, "ig_media_count": 100, "total_likes": 80, "total_comments": 20},
            {"hashtag": "#b", "our_post_count": 1, "avg_engagement": 500, "ig_media_count": 200, "total_likes": 400, "total_comments": 100},
        ]
        df = DataProcessor.process_hashtags(raw)
        assert df.iloc[0]["hashtag"] == "#b"


