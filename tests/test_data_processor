class TestBestTimes:
    def test_returns_dataframe(self, sample_posts):
        posts_df = DataProcessor.process_posts(sample_posts)
        df = DataProcessor.compute_best_times(posts_df)
        assert isinstance(df, pd.DataFrame)

    def test_columns(self, sample_posts):
        posts_df = DataProcessor.process_posts(sample_posts)
        df = DataProcessor.compute_best_times(posts_df)
        if not df.empty:
            assert "weekday" in df.columns
            assert "hour" in df.columns
            assert "avg_engagement_rate" in df.columns
